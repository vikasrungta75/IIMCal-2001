# ─── REQUIRED ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-very-long-random-secret-here

# Your production URL (no trailing slash)
NEXTAUTH_URL=https://your-project.vercel.app

# ─── GOOGLE OAUTH (free) ─────────────────────────────────────────────
# Setup: https://console.cloud.google.com
# 1. New Project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 2. Authorized redirect URIs: https://your-project.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── MICROSOFT / HOTMAIL OAUTH (free) ───────────────────────────────
# Setup: https://portal.azure.com → App registrations → New registration
# 1. Supported account types: "Personal Microsoft accounts only" (for Hotmail/Outlook)
#    OR "Accounts in any organizational directory and personal" (for both)
# 2. Redirect URI: https://your-project.vercel.app/api/auth/callback/azure-ad
# 3. Certificates & secrets → New client secret
AZURE_AD_CLIENT_ID=your-azure-app-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=common

# ─── LEGACY JWT (kept for backwards compat) ─────────────────────────
JWT_SECRET=same-as-nextauth-secret-or-different
